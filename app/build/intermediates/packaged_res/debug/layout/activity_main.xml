<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_card_bg"
        app:tabIndicatorColor="@color/color_bpm"
        app:tabSelectedTextColor="@color/color_title"
        app:tabTextColor="@color/color_subtitle">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_monitor" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_logs" />
    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ── MONITOR TAB ── -->
        <ScrollView
            android:id="@+id/layoutMonitor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Title Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/ivHeartIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="10dp"
                        android:gravity="center"
                        android:text="♥"
                        android:textColor="@color/color_bpm"
                        android:textSize="28sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pulse &amp; SpO2 Monitor"
                            android:textColor="@color/color_title"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Samsung Galaxy Note 9"
                            android:textColor="@color/color_subtitle"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Status Text -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:gravity="center"
                    android:minHeight="36dp"
                    android:text="Press START to begin"
                    android:textColor="@color/color_status"
                    android:textSize="13sp" />

                <!-- Accuracy indicator -->
                <TextView
                    android:id="@+id/tvAccuracy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center"
                    android:textSize="12sp" />

                <!-- ── Measurement Cards ── -->
                <LinearLayout
                    android:id="@+id/measurementCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- BPM Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/color_card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.15"
                                android:text="HEART RATE"
                                android:textColor="@color/color_subtitle"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/tvBpm"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="2dp"
                                android:text="--"
                                android:textColor="@color/color_bpm"
                                android:textSize="52sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BPM"
                                android:textColor="@color/color_subtitle"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvBpmAvg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/color_subtitle"
                                android:textSize="11sp" />

                            <!-- Normal range indicator -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/range_badge_red"
                                android:gravity="center"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Normal: 60–100"
                                android:textColor="@color/color_hint"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- SpO2 Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/color_card_bg"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.15"
                                android:text="BLOOD OXYGEN"
                                android:textColor="@color/color_subtitle"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/tvSpo2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="2dp"
                                android:text="--"
                                android:textColor="@color/color_spo2"
                                android:textSize="52sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SpO2 %"
                                android:textColor="@color/color_subtitle"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvSpo2Avg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textColor="@color/color_subtitle"
                                android:textSize="11sp" />

                            <!-- Normal range indicator -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/range_badge_blue"
                                android:gravity="center"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="Normal: 95–100%"
                                android:textColor="@color/color_hint"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Instruction Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="@color/color_instruction_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="How to measure"
                            android:textColor="@color/color_title"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="2dp"
                            android:text="1.  Place your fingertip firmly over the heart rate sensor on the back of your phone (next to the camera).\n\n2.  Keep still — movement causes inaccurate readings.\n\n3.  Wait 10–20 seconds for the reading to stabilize.\n\n4.  The sensor requires gentle but firm pressure."
                            android:textColor="@color/color_subtitle"
                            android:textSize="13sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Start / Stop Button -->
                <Button
                    android:id="@+id/btnToggle"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="@color/color_start_btn"
                    android:text="▶  Start"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Save Button -->
                <Button
                    android:id="@+id/btnSave"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="@color/color_save_btn"
                    android:text="@string/btn_save"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Sensor Info Toggle -->
                <TextView
                    android:id="@+id/tvSensorInfoToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Show sensor info ▼"
                    android:textColor="@color/color_subtitle"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvSensorInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@color/color_card_bg"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:textColor="@color/color_subtitle"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <!-- Disclaimer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="⚠ Not for medical use. Consumer-grade sensors may vary in accuracy. Always consult a medical professional for health concerns."
                    android:textColor="@color/color_hint"
                    android:textSize="11sp" />

            </LinearLayout>
        </ScrollView>

        <!-- ── LOGS TAB ── -->
        <ScrollView
            android:id="@+id/layoutLogs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/logsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="@string/logs_title"
                    android:textColor="@color/color_title"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNoLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="40dp"
                    android:text="@string/no_logs"
                    android:textColor="@color/color_hint" />

            </LinearLayout>
        </ScrollView>

    </FrameLayout>
</LinearLayout>
